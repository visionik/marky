{
  "name": "crackdown",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages/",
    "fmt": "prettier --write 'packages/*/src/**/*.ts'",
    "fmt:check": "prettier --check 'packages/*/src/**/*.ts'",
    "clean": "pnpm -r --if-present clean"
  },
  "devDependencies": {
    "@crackdown/cli": "workspace:*",
    "@crackdown/compat-markdownlint": "workspace:*",
    "@crackdown/core": "workspace:*",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
