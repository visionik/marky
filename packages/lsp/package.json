{
  "name": "@crackdown/lsp",
  "version": "0.1.0",
  "type": "module",
  "description": "LSP server for crackdown Markdown linter",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "crackdown-lsp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@crackdown/core": "workspace:*",
    "vscode-languageserver": "^9.0.0",
    "vscode-languageserver-textdocument": "^1.0.0",
    "vscode-uri": "^3.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "*",
    "unified-lint-rule": "^3.0.1",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3"
  }
}
